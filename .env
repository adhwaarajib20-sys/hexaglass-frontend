# Konfigurasi Backend API
# PENTING: Ganti IP dengan IP backend server Anda

# Untuk development di localhost:
# EXPO_PUBLIC_API_URL=http://localhost:8000/api

# Untuk Android Emulator (ganti XXX dengan IP laptop Anda):
# EXPO_PUBLIC_API_URL=http://192.168.XXX.XXX:8000/api

# Untuk device fisik (ganti XXX dengan IP server Anda):
EXPO_PUBLIC_API_URL=http://192.168.1.7:8000/api
